<!DOCTYPE html>
<html lang="es">
<head><%- include('partials/head', {title:'Registrarse'}) %></head>
<body class="auth-bg">
<div class="auth-container">
  <div class="auth-card card z-depth-3" style="max-width:540px">
    <div class="auth-logo"><i class="material-icons large">person_add</i></div>
    <h5 class="center-align">Crear cuenta</h5>
    <div id="alert" class="auth-alert" style="display:none"></div>
    <div class="row" style="margin-bottom:0">
      <div class="input-field col s12 m6">
        <i class="material-icons prefix">person</i>
        <input id="name" type="text"/><label for="name">Nombre</label>
      </div>
      <div class="input-field col s12 m6">
        <i class="material-icons prefix">person_outline</i>
        <input id="lastName" type="text"/><label for="lastName">Apellido</label>
      </div>
    </div>
    <div class="input-field">
      <i class="material-icons prefix">email</i>
      <input id="email" type="email"/><label for="email">Email</label>
    </div>
    <div class="input-field">
      <i class="material-icons prefix">phone</i>
      <input id="phoneNumber" type="tel"/><label for="phoneNumber">Teléfono</label>
    </div>
    <div class="input-field">
      <i class="material-icons prefix">cake</i>
      <input id="birthdate" type="date"/><label for="birthdate" class="active">Fecha de nacimiento</label>
    </div>
    <div class="input-field">
      <i class="material-icons prefix">lock_outline</i>
      <input id="password" type="password"/>
      <label for="password">Contraseña</label>
      <span class="helper-text">Min 8 chars, 1 mayúscula, 1 dígito, 1 especial (#$%&*@)</span>
    </div>
    <button class="btn btn-block waves-effect waves-light" onclick="doSignUp()">
      Registrarse <i class="material-icons right">how_to_reg</i>
    </button>
    <p class="center-align auth-link">¿Ya tienes cuenta? <a href="/signIn">Iniciar sesión</a></p>
  </div>
</div>
<script>
async function doSignUp(){
  const body={
    name:document.getElementById('name').value,
    lastName:document.getElementById('lastName').value,
    email:document.getElementById('email').value,
    phoneNumber:document.getElementById('phoneNumber').value,
    birthdate:document.getElementById('birthdate').value,
    password:document.getElementById('password').value,
    roles:['user']
  };
  const res=await fetch('/api/auth/signUp',{
    method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)
  });
  const data=await res.json();
  if(!res.ok) return showAlert(data.message);
  location.href='/signIn';
}
function showAlert(msg){
  const el=document.getElementById('alert');
  el.textContent=msg; el.style.display='block';
}
</script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
</body></html>