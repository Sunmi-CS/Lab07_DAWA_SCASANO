<!DOCTYPE html>
<html lang="es">
<head><%- include('partials/head', {title:'Iniciar sesión'}) %></head>
<body class="auth-bg">
<div class="auth-container">
  <div class="auth-card card z-depth-3">
    <div class="auth-logo"><i class="material-icons large">lock</i></div>
    <h5 class="center-align">Iniciar sesión</h5>
    <div id="alert" class="auth-alert" style="display:none"></div>
    <div class="input-field">
      <i class="material-icons prefix">email</i>
      <input id="email" type="email" placeholder="correo@ejemplo.com"/>
      <label for="email">Email</label>
    </div>
    <div class="input-field">
      <i class="material-icons prefix">lock_outline</i>
      <input id="password" type="password" placeholder="Tu contraseña"/>
      <label for="password">Contraseña</label>
    </div>
    <button class="btn btn-block waves-effect waves-light" onclick="doSignIn()">
      Ingresar <i class="material-icons right">send</i>
    </button>
    <p class="center-align auth-link">¿No tienes cuenta? <a href="/signUp">Regístrate</a></p>
  </div>
</div>
<script>
async function doSignIn(){
  const email=document.getElementById('email').value;
  const password=document.getElementById('password').value;
  const res=await fetch('/api/auth/signIn',{
    method:'POST',headers:{'Content-Type':'application/json'},
    body:JSON.stringify({email,password})
  });
  const data=await res.json();
  if(!res.ok) return showAlert(data.message);
  sessionStorage.setItem('token', data.token);
  sessionStorage.setItem('roles', JSON.stringify(data.roles));
  document.cookie=`token=${data.token};path=/;SameSite=Strict`;
  const roles=data.roles||[];
  if(roles.includes('admin')) location.href='/dashboard/admin';
  else location.href='/dashboard/user';
}
function showAlert(msg){
  const el=document.getElementById('alert');
  el.textContent=msg; el.style.display='block';
}
</script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
</body></html>