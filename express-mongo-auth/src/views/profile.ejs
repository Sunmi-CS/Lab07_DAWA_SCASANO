<!DOCTYPE html>
<html lang="es">
<head><%- include('partials/head', {title:'Mi perfil'}) %></head>
<body>
<%- include('partials/navbar') %>
<main class="container" style="margin-top:2rem">
  <div class="row">
    <div class="col s12 m4 center-align">
      <img id="profile-img" src="https://via.placeholder.com/120" class="circle responsive-img" style="width:120px;height:120px;object-fit:cover;border:3px solid #26a69a"/>
      <h5 id="profile-name">Cargando...</h5>
      <span id="profile-role" class="chip teal lighten-4 teal-text text-darken-3"></span>
      <p id="profile-age" class="grey-text"></p>
    </div>
    <div class="col s12 m8">
      <div class="card">
        <div class="card-content">
          <span class="card-title">Editar información</span>
          <div id="alert" class="auth-alert" style="display:none"></div>
          <div id="success" class="auth-success" style="display:none"></div>
          <div class="row" style="margin-bottom:0">
            <div class="input-field col s12 m6">
              <input id="name" type="text"/><label for="name" class="active">Nombre</label>
            </div>
            <div class="input-field col s12 m6">
              <input id="lastName" type="text"/><label for="lastName" class="active">Apellido</label>
            </div>
          </div>
          <div class="input-field">
            <input id="phoneNumber" type="tel"/><label for="phoneNumber" class="active">Teléfono</label>
          </div>
          <div class="input-field">
            <input id="birthdate" type="date"/><label for="birthdate" class="active">Fecha de nacimiento</label>
          </div>
          <div class="input-field">
            <input id="address" type="text"/><label for="address" class="active">Dirección</label>
          </div>
          <div class="input-field">
            <input id="url_profile" type="url"/><label for="url_profile" class="active">URL de foto de perfil</label>
          </div>
          <button class="btn waves-effect waves-light" onclick="guardar()">
            <i class="material-icons left">save</i> Guardar cambios
          </button>
        </div>
      </div>
    </div>
  </div>
</main>
<script>
async function loadProfile(){
  const token=sessionStorage.getItem('token');
  if(!token){location.href='/signIn';return;}
  const res=await fetch('/api/users/me',{headers:{Authorization:'Bearer '+token}});
  if(res.status===401){location.href='/signIn';return;}
  const u=await res.json();
  document.getElementById('profile-name').textContent=`${u.name} ${u.lastName}`;
  document.getElementById('profile-role').textContent=u.roles.join(' | ');
  document.getElementById('profile-age').textContent=`${u.edad} años`;
  if(u.url_profile) document.getElementById('profile-img').src=u.url_profile;
  const fill=(id,val)=>{const el=document.getElementById(id);if(el&&val!==undefined)el.value=val;};
  fill('name',u.name); fill('lastName',u.lastName);
  fill('phoneNumber',u.phoneNumber);
  fill('birthdate',u.birthdate?u.birthdate.split('T')[0]:'');
  fill('address',u.address); fill('url_profile',u.url_profile);
}
async function guardar(){
  const token=sessionStorage.getItem('token');
  const body={
    name:document.getElementById('name').value,
    lastName:document.getElementById('lastName').value,
    phoneNumber:document.getElementById('phoneNumber').value,
    birthdate:document.getElementById('birthdate').value,
    address:document.getElementById('address').value,
    url_profile:document.getElementById('url_profile').value,
  };
  const res=await fetch('/api/users/me',{
    method:'PUT',headers:{'Content-Type':'application/json','Authorization':'Bearer '+token},
    body:JSON.stringify(body)
  });
  const data=await res.json();
  if(!res.ok){
    const el=document.getElementById('alert');el.textContent=data.message;el.style.display='block';
    return;
  }
  const s=document.getElementById('success');s.textContent='Perfil actualizado correctamente';s.style.display='block';
  setTimeout(()=>{s.style.display='none';},3000);
  loadProfile();
}
loadProfile();
</script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
</body></html>